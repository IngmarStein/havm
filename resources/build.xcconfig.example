// havm build configuration
// Copy this file to resources/build.xcconfig and set your team ID:
//
//   cp resources/build.xcconfig.example resources/build.xcconfig

// Your Apple Developer Team ID (find at https://developer.apple.com/account)
// Leave empty for ad-hoc signing.
DEVELOPMENT_TEAM =

// Code signing identity:
//   "-"                  — ad-hoc signing
//   "Apple Development"  — requires DEVELOPMENT_TEAM
CODE_SIGN_IDENTITY = -

// Entitlement tier:
//   1 — Free account (VM + hypervisor only, no USB, no bridge)
//   2 — Paid account (adds USB accessory passthrough)
//   3 — Paid + Apple approval (adds bridged networking)
ENTITLEMENTS_TIER = 1
